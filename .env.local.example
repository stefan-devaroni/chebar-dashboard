# Supabase — get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only (used by seed script)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=stefan@chebararuba.com,manager@chebararuba.com

# Claude API — for report analysis + review response generation
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Business Profile — for review management (optional)
# Setup: https://developers.google.com/my-business/content/review-data
GOOGLE_ACCOUNT_ID=
GOOGLE_LOCATION_ID=
GOOGLE_ACCESS_TOKEN=

# Email ingest — shared secret to authenticate SendGrid webhook
# Generate with: openssl rand -hex 20
INGEST_EMAIL_SECRET=your_random_secret_here
